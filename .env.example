# =============================================================================
# GLI-FLOW Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For local SQLite development (default): leave DATABASE_URL unset
# For Supabase/PostgreSQL: set DATABASE_URL to your connection string
# =============================================================================

# --- Database ---
# PostgreSQL connection string (Supabase).
# When set, GLI-FLOW uses PostgreSQL instead of SQLite.
# Format: postgresql://postgres.<project>:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres.abcd1234:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# SQLite database path override (optional).
# Only used when DATABASE_URL is not set.
# GLI_FLOW_DB=/home/user/.gli_flow/gli_flow.db
# GLI_FLOW_DB_PATH=/home/user/.gli_flow/gli_flow.db

# --- Supabase (optional, for client-side operations) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Backend ---
# Port for the FastAPI backend server
# GLI_FLOW_BACKEND_PORT=8000

# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- AI / BharatCode ---
# BHARATCODE_API_KEY=your-api-key

# --- Telemetry ---
# Upload destination URL
# GLI_FLOW_TELEMETRY_URL=https://your-api.example.com/ingest
