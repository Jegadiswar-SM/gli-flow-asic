# =========================================
# GLI-FLOW Repository Hygiene
# =========================================

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg

# Virtual environments
venv/
.env
.env/

# Runtime output directories (code in outputs/ IS tracked)
outputs/runs/
outputs/reports/
outputs/metrics/latest_metrics.json
outputs/replay/replay_index.json

# OpenROAD / LibreLane execution artifacts
openroad_runs/
runs/

# Snapshot artifacts
/snapshots/

# Packaging outputs
*.tar.gz

# Telemetry artifacts
telemetry_snapshot.json

# Temporary files
*.tmp
*.log
*.swp
*.bak

# OS files
.DS_Store
Thumbs.db

# IDE/editor files
.vscode/
.idea/

# Environment validation artifacts
environment/*.report.json

# Generated manifests/reports
*_report.json
*_snapshot.json
*_metrics.json

# Local databases
*.db
*.sqlite

# Testing artifacts
.coverage
pytest_cache/

# Build artifacts
build/
dist/

# Node modules
node_modules/

# Dashboard build output
dashboard/dist/

# Docker temporary state
docker_tmp/

# Generated design and telemetry files
*.ext
*.spice
latest.json
coverage_taxonomy.json
golden_design_catalog.json
golden_telemetry_export.json

# Local run data
counter_reports/

# Design run outputs
designs/*/runs/

# Workspace mirror / dev-only clutter
home/
tmp/
handover.md

# Magic VLSI session files
-zz

# Mini-MaC example (has its own git repo)
examples/Mini-MaC/
examples/mini_mac/dv/obj_dir/
*.vcd
