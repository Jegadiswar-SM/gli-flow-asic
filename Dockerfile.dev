FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

ENV PDK_ROOT=/pdk
ENV PATH="/usr/local/bin:${PATH}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget ca-certificates build-essential cmake \
    python3 python3-pip python3-venv python3-dev \
    tcl tcl-dev tk-dev libffi-dev libssl-dev libgomp1 libtcl8.6 \
    yosys klayout netgen-lvs magic \
 && rm -rf /var/lib/apt/lists/*

RUN wget -q \
    https://github.com/Precision-Innovations/OpenROAD/releases/download/2024-12-14/openroad_2.0-17598-ga008522d8_amd64-ubuntu-22.04.deb \
    -O /tmp/openroad.deb \
 && apt-get update \
 && apt-get install -y --no-install-recommends /tmp/openroad.deb \
 && rm /tmp/openroad.deb \
 && rm -rf /var/lib/apt/lists/*

RUN yosys -V && openroad -version && magic -noconsole -dnull -version 2>&1 | head -3 || true

RUN pip3 install --no-cache-dir click rich pyyaml jinja2 tabulate pytest pytest-xdist

WORKDIR /gli-flow
COPY . /gli-flow
RUN pip3 install --no-cache-dir -e .

CMD ["gli-flow", "--help"]
